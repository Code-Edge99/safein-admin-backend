{
  "name": "safein-admin-backend",
  "version": "1.0.0",
  "description": "Safein Admin Backend - NestJS with Prisma",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "postinstall": "node scripts/setup-prisma-client.js",
    "build": "nest build",
    "dev": "nest start --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "node -e \"console.error('Use smombie-prisma: npm --prefix ../smombie-prisma run prisma:generate'); process.exit(1)\"",
    "prisma:migrate": "node -e \"console.error('Use smombie-prisma: npm --prefix ../smombie-prisma run prisma:migrate'); process.exit(1)\"",
    "prisma:migrate:prod": "node -e \"console.error('Use smombie-prisma: npm --prefix ../smombie-prisma run prisma:migrate:deploy'); process.exit(1)\"",
    "prisma:studio": "node -e \"console.error('Use smombie-prisma: npm --prefix ../smombie-prisma run prisma:studio'); process.exit(1)\"",
    "prisma:seed": "node -e \"console.error('Use smombie-prisma: npm --prefix ../smombie-prisma run prisma:seed'); process.exit(1)\"",
    "db:push": "node -e \"console.error('Use smombie-prisma for schema operations.'); process.exit(1)\"",
    "db:reset": "node -e \"console.error('Use smombie-prisma for schema operations.'); process.exit(1)\""
  },
  "prisma": {
    "seed": "node -e \"console.error('Use smombie-prisma: npm --prefix ../smombie-prisma run prisma:seed'); process.exit(1)\"",
    "schema": "../smombie-prisma/prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^5.7.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "helmet": "^8.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^24.12.2",
    "@types/passport-jwt": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "prisma": "^5.7.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  },
  "overrides": {
    "path-to-regexp": "8.4.2",
    "picomatch": "4.0.4",
    "tar": "7.5.13",
    "@tootallnate/once": "^3.0.1"
  }
}
